{
    "version": "0.1.0",
    "description": "Bidirectional sync of Helium browser bookmarks + saved tab groups across Windows machines, using your own private git repo as the transport. CLI, no extension.",
    "homepage": "https://github.com/tinywifi/helium-sync-windows",
    "license": "MIT",
    "suggest": {
        "Python": ["python"]
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/tinywifi/helium-sync-windows/releases/download/v0.1.0/helium-sync-windows-v0.1.0-amd64.zip",
            "hash": "sha256:6da5171fa698516203177a0516814fdc5453bb13a38954d56af5bbac5e091730"
        },
        "arm64": {
            "url": "https://github.com/tinywifi/helium-sync-windows/releases/download/v0.1.0/helium-sync-windows-v0.1.0-arm64.zip",
            "hash": "sha256:03ce1b4ef5614f27baa1a4e18e5421559c892bcdc21d46178a6b621f420eef2b"
        }
    },
    "post_install": [
        "$install_dir = Join-Path (Split-Path $dir) $version",
        "python -m venv \"$install_dir\\.venv\"",
        "& \"$install_dir\\.venv\\Scripts\\python\" -m pip install --quiet -r \"$install_dir\\requirements.txt\""
    ],
    "env_set": {
        "HELIUM_SYNC_VERSION": "$version"
    },
    "notes": [
        "helium-sync stores user config outside the Scoop app directory at %APPDATA%\\helium-sync\\config.toml.",
        "Your sync data repo is not removed by Scoop uninstall. Check `helium-sync doctor` or the config file for its path.",
        "To fully remove local config after uninstall, delete %APPDATA%\\helium-sync manually."
    ],
    "post_uninstall": [
        "Write-Host \"helium-sync config and sync data were left in place.\"",
        "Write-Host \"Delete %APPDATA%\\helium-sync manually only if you no longer need this device config.\""
    ],
    "bin": [["bin\\helium-sync.bat", "helium-sync"]],
    "checkver": {
        "github": "https://github.com/tinywifi/helium-sync-windows"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/tinywifi/helium-sync-windows/releases/download/v$version/helium-sync-windows-v$version-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/tinywifi/helium-sync-windows/releases/download/v$version/helium-sync-windows-v$version-arm64.zip"
            }
        }
    }
}
