#!/usr/bin/env python3
"""helium-sync — keep Helium bookmarks and saved tab groups in sync between
devices via a private git repo. Modeled on git push/pull.

Usage:
  helium-sync status       Show what's going on (read-only)
  helium-sync push         Snapshot this device -> repo -> origin
                           (close Helium first)
  helium-sync pull         origin -> repo -> this device's live profile
                           (close Helium first)
  helium-sync doctor       Check local install and sync prerequisites
  helium-sync version      Print version and runtime details
  helium-sync init         First-time: declare this device the source of truth
  helium-sync adopt        First-time on a new device: receive canonical state

The mental model is git: pull at the start of a session, push at the end. If
you forget, the un-pushed device's changes are lost on the next pull. Every
modification writes a timestamped backup under logs/.
"""

# ──────────────────────────────────────────────────────────────────────────
# Auto-relaunch under the repo's .venv so third-party deps (protobuf) resolve
# regardless of which python is on PATH. Stdlib-only above this block.
# ──────────────────────────────────────────────────────────────────────────
import os
import sys
from pathlib import Path

_self = Path(__file__).resolve()
_repo = _self.parent.parent

_venv_py = _repo / ".venv" / "Scripts" / "python.exe"

if _venv_py.exists() and Path(sys.executable).resolve() != _venv_py.resolve():
    import subprocess as _sp
    raise SystemExit(_sp.run([str(_venv_py), str(_self), *sys.argv[1:]]).returncode)

# ──────────────────────────────────────────────────────────────────────────
# Now under .venv (or the user accepted system python).
# ──────────────────────────────────────────────────────────────────────────
import argparse
import json
import os
import re
import shutil
import socket
import subprocess
import tomllib
import urllib.request
from datetime import datetime, timedelta, timezone
from typing import Any, Iterator, Optional

sys.path.insert(0, str(_self.parent))
from targets import ALL_TARGETS  # noqa: E402

SCRIPT_DIR = _self.parent


def _default_config() -> Path:
    appdata = os.environ.get("APPDATA") or str(Path.home() / "AppData" / "Roaming")
    return Path(appdata) / "helium-sync" / "config.toml"


def _default_profile() -> Path:
    localappdata = os.environ.get("LOCALAPPDATA") or str(Path.home() / "AppData" / "Local")
    return Path(localappdata) / "imput" / "Helium" / "User Data"


DEFAULT_REPO = _self.parent.parent
DEFAULT_CONFIG = _default_config()
DEFAULT_PROFILE = _default_profile()
LATEST_RELEASE_URL = "https://api.github.com/repos/tinywifi/helium-sync-windows/releases/latest"

# Resolved at runtime — bound by main() before any cmd_* runs.
REPO_ROOT: Path = DEFAULT_REPO
STATE_DIR: Path = REPO_ROOT / "state"
LOGS_DIR: Path = REPO_ROOT / "logs"


def _resolve_repo(cli_arg: Path | None, env: dict, config_path: Path) -> Path:
    """Choose the data-repo directory by precedence:
       1. --repo flag (cli_arg)
       2. HELIUM_SYNC_REPO env var
       3. `repo = "..."` in config_path (TOML)
       4. DEFAULT_REPO (backward compat: parent of this script)

    Pure function — pass dependencies explicitly so tests can simulate any
    combination without polluting the real environment.
    """
    if cli_arg is not None:
        return Path(cli_arg).expanduser().resolve()
    env_val = env.get("HELIUM_SYNC_REPO")
    if env_val:
        return Path(env_val).expanduser().resolve()
    if config_path.is_file():
        try:
            cfg = tomllib.loads(config_path.read_text())
            cfg_repo = cfg.get("repo")
            if cfg_repo:
                return Path(cfg_repo).expanduser().resolve()
        except (tomllib.TOMLDecodeError, OSError):
            pass
    return DEFAULT_REPO.resolve()


# ──────────────────────────────────────────────────────────────────────────
# Helpers
# ──────────────────────────────────────────────────────────────────────────

def hostname() -> str:
    return socket.gethostname()


def helium_running() -> bool:
    r = subprocess.run(
        ["tasklist", "/FI", "IMAGENAME eq helium.exe", "/NH"],
        capture_output=True, text=True,
    )
    return "helium.exe" in r.stdout.lower()


def now_iso() -> str:
    return datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")


def now_stamp() -> str:
    return datetime.now().strftime("%Y%m%d-%H%M%S")


def run_git(args: list, check: bool = True) -> subprocess.CompletedProcess:
    return subprocess.run(
        ["git", "-C", str(REPO_ROOT), *args],
        capture_output=True, text=True, check=check,
    )


def _has_upstream() -> bool:
    """True if the current branch has an upstream tracking branch configured."""
    r = run_git(["rev-parse", "--abbrev-ref", "@{upstream}"], check=False)
    return r.returncode == 0


def _has_remote() -> bool:
    """True if an 'origin' remote is configured (even without a tracking branch)."""
    r = run_git(["remote", "get-url", "origin"], check=False)
    return r.returncode == 0


def _git_available() -> bool:
    return shutil.which("git") is not None


def _leveldb_writer_path() -> Path:
    return SCRIPT_DIR / ("leveldb-writer.exe" if os.name == "nt" else "leveldb-writer")


def _is_scoop_install() -> bool:
    parts = [part.lower() for part in _repo.parts]
    return "scoop" in parts and "apps" in parts and "helium-sync" in parts


def _app_version() -> str:
    env_version = os.environ.get("HELIUM_SYNC_VERSION")
    if env_version:
        return env_version
    if _repo.name == "current":
        parent_version = _repo.parent.name
        if re.fullmatch(r"\d+\.\d+\.\d+(?:[-+][0-9A-Za-z.-]+)?", parent_version):
            return parent_version
    if re.fullmatch(r"\d+\.\d+\.\d+(?:[-+][0-9A-Za-z.-]+)?", _repo.name):
        return _repo.name
    revision = _git_revision()
    if revision.startswith("v"):
        return revision[1:]
    return "unknown"


def _git_revision() -> str:
    if not (_repo / ".git").exists() or not _git_available():
        return "not available"
    desc = subprocess.run(
        ["git", "-C", str(_repo), "describe", "--tags", "--dirty", "--always"],
        capture_output=True, text=True, check=False,
    )
    return (desc.stdout or "not available").strip()


def _version_tuple(version: str) -> tuple[int, ...] | None:
    match = re.match(r"^v?(\d+)\.(\d+)\.(\d+)", version)
    if not match:
        return None
    return tuple(int(part) for part in match.groups())


def _latest_release_version() -> str | None:
    try:
        req = urllib.request.Request(
            LATEST_RELEASE_URL,
            headers={
                "Accept": "application/vnd.github+json",
                "User-Agent": "helium-sync",
            },
        )
        with urllib.request.urlopen(req, timeout=2) as response:
            payload = json.loads(response.read().decode("utf-8"))
    except Exception:
        return None
    tag = payload.get("tag_name")
    if isinstance(tag, str) and tag:
        return tag[1:] if tag.startswith("v") else tag
    return None


def _update_banner(current: str, latest: str) -> str:
    lines = [
        f" Update available: helium-sync {current} -> {latest} ",
        " Run: scoop update && scoop update helium-sync ",
    ]
    width = max(len(line) for line in lines)
    border = "+" + "-" * width + "+"
    body = [border]
    body.extend("|" + line.ljust(width) + "|" for line in lines)
    body.append(border)
    return "\n".join(body)


def maybe_show_update_banner() -> None:
    if os.environ.get("HELIUM_SYNC_NO_UPDATE_CHECK"):
        return
    current = _app_version()
    current_tuple = _version_tuple(current)
    if current_tuple is None:
        return
    latest = _latest_release_version()
    latest_tuple = _version_tuple(latest or "")
    if latest and latest_tuple and latest_tuple > current_tuple:
        print(_update_banner(current, latest))
        print()


def log(msg: str) -> None:
    line = f"{now_iso()} {msg}"
    print(line)
    LOGS_DIR.mkdir(parents=True, exist_ok=True)
    with open(LOGS_DIR / "sync.log", "a") as f:
        f.write(line + "\n")


def _url_scheme(url: str) -> str:
    """Return the scheme portion of a URL, or '' if none found."""
    if "://" in url:
        return url.split("://", 1)[0].lower()
    return ""


def _validate_bookmarks(data: dict) -> list[str]:
    """Validate bookmark tree structure. Returns list of warning messages."""
    issues: list[str] = []
    if "roots" not in data:
        issues.append("missing 'roots' key in bookmark data")
        return issues
    _BOOKMARK_ROOT_KEYS = ("bookmark_bar", "other", "synced")
    for rk in _BOOKMARK_ROOT_KEYS:
        if rk not in data["roots"]:
            issues.append(f"missing root '{rk}' in bookmark data")

    # Walk tree for node-level checks
    for root in data.get("roots", {}).values():
        for node in _walk_all_nodes(root):
            if node.get("type") == "url":
                url = node.get("url", "")
                if not url:
                    issues.append(f"bookmark '{node.get('name', '?')}' has empty URL")
                elif _url_scheme(url) and _url_scheme(url) not in ("http", "https", "chrome", "file"):
                    issues.append(f"bookmark '{node.get('name', '?')}': unusual URL scheme '{_url_scheme(url)}'")
            elif node.get("type") == "folder" and not node.get("name"):
                issues.append("unnamed folder detected in bookmark tree")
    return issues


def _walk_all_nodes(node: dict) -> Iterator[dict]:
    """Yield every node in the bookmark tree (URLs and folders)."""
    yield node
    for c in node.get("children") or []:
        yield from _walk_all_nodes(c)


def _validate_tab_groups(data: dict) -> list[str]:
    """Validate saved tab groups data. Returns list of warning messages."""
    issues: list[str] = []
    if "groups" not in data or "tabs" not in data:
        issues.append("missing 'groups' or 'tabs' key in tab group data")
        return issues

    group_guids = set(data["groups"])
    for guid, g in data["groups"].items():
        if not g.get("title"):
            issues.append(f"group '{guid[:8]}…' has empty title")

    for guid, t in data["tabs"].items():
        url = t.get("url", "")
        if not url:
            issues.append(f"tab '{guid[:8]}…' has empty URL")
        elif _url_scheme(url) and _url_scheme(url) not in ("http", "https", "chrome", "file"):
            issues.append(f"tab '{guid[:8]}…': unusual URL scheme '{_url_scheme(url)}'")
        if t.get("group_guid") and t["group_guid"] not in group_guids:
            issues.append(f"tab '{guid[:8]}…' references non-existent group '{t['group_guid'][:8]}…'")
    return issues


def _tab_group_divergences(live: dict, canonical: dict) -> dict:
    """Classify divergences between two saved-tab-group states.

    Returns a dict with six sets of GUIDs:
      live_only_groups / canon_only_groups / conflict_groups
      live_only_tabs   / canon_only_tabs   / conflict_tabs
    """
    lg = live.get("groups", {})
    lt = live.get("tabs", {})
    cg = canonical.get("groups", {})
    ct = canonical.get("tabs", {})

    live_only_groups  = set(lg) - set(cg)
    canon_only_groups = set(cg) - set(lg)
    conflict_groups   = {
        guid for guid in (set(lg) & set(cg))
        if (lg[guid].get("title") != cg[guid].get("title") or
            lg[guid].get("color") != cg[guid].get("color"))
    }

    live_only_tabs  = set(lt) - set(ct)
    canon_only_tabs = set(ct) - set(lt)
    conflict_tabs   = {
        guid for guid in (set(lt) & set(ct))
        if (lt[guid].get("url")        != ct[guid].get("url") or
            lt[guid].get("title")      != ct[guid].get("title") or
            lt[guid].get("group_guid") != ct[guid].get("group_guid"))
    }

    return {
        "live_only_groups":  live_only_groups,
        "canon_only_groups": canon_only_groups,
        "conflict_groups":   conflict_groups,
        "live_only_tabs":    live_only_tabs,
        "canon_only_tabs":   canon_only_tabs,
        "conflict_tabs":     conflict_tabs,
    }


def _merge_tab_groups(live: dict, canonical: dict, selections: list) -> dict:
    """Build a merged tab-group state from interactive TUI selections.

    selections: list of dicts with keys:
      type        "group" | "tab"
      guid        str
      source      "local" | "canonical" | "conflict"
      keep        bool  — for local/canonical: include; for conflict: keep live version
      keep_theirs bool  — conflict only: True → use canonical version
    """
    lg = live.get("groups", {})
    lt = live.get("tabs", {})
    cg = canonical.get("groups", {})
    ct = canonical.get("tabs", {})

    divergent_group_guids = {s["guid"] for s in selections if s["type"] == "group"}
    divergent_tab_guids   = {s["guid"] for s in selections if s["type"] == "tab"}

    merged_groups: dict = {}
    merged_tabs:   dict = {}

    # Unchanged groups (same in both; use live copy)
    for guid in (set(lg) | set(cg)) - divergent_group_guids:
        merged_groups[guid] = lg[guid] if guid in lg else cg[guid]

    # Divergent groups from TUI selections
    for sel in selections:
        if sel["type"] != "group":
            continue
        guid = sel["guid"]
        if sel["source"] == "conflict":
            if sel.get("keep_theirs") and guid in cg:
                merged_groups[guid] = cg[guid]
            elif sel.get("keep") and guid in lg:
                merged_groups[guid] = lg[guid]
        elif sel.get("keep"):
            pool = lg if sel["source"] == "local" else cg
            if guid in pool:
                merged_groups[guid] = pool[guid]

    # Unchanged tabs
    for guid in (set(lt) | set(ct)) - divergent_tab_guids:
        merged_tabs[guid] = lt[guid] if guid in lt else ct[guid]

    # Divergent tabs from TUI selections
    for sel in selections:
        if sel["type"] != "tab":
            continue
        guid = sel["guid"]
        if sel["source"] == "conflict":
            if sel.get("keep_theirs") and guid in ct:
                merged_tabs[guid] = ct[guid]
            elif sel.get("keep") and guid in lt:
                merged_tabs[guid] = lt[guid]
        elif sel.get("keep"):
            pool = lt if sel["source"] == "local" else ct
            if guid in pool:
                merged_tabs[guid] = pool[guid]

    return {"groups": merged_groups, "tabs": merged_tabs}


# ──────────────────────────────────────────────────────────────────────────
# Commands
# ──────────────────────────────────────────────────────────────────────────

def cmd_setup(args: argparse.Namespace) -> int:
    """Interactive first-time setup.

    Branches automatically:
      - empty remote URL  -> init flow (this device is the source of truth)
      - URL pointing at an empty repo  -> init flow
      - URL pointing at a repo with existing main -> adopt flow
    """
    if DEFAULT_CONFIG.exists() and not args.force:
        try:
            current_repo = tomllib.loads(DEFAULT_CONFIG.read_text()).get("repo", "(unparseable)")
        except tomllib.TOMLDecodeError:
            current_repo = "(unparseable)"
        print(f"Already configured: {DEFAULT_CONFIG}")
        print(f"  data repo: {current_repo}")
        print()
        print("Pass --force to reconfigure (existing config will be overwritten).")
        return 8

    print("helium-sync needs a private git repo to store your bookmarks and tab groups.")
    print()

    default_repo = Path.home() / "helium-data"
    repo_input = _ask(f"Where should it live? [{default_repo}]: ", default=str(default_repo))
    repo_path = Path(repo_input).expanduser().resolve()
    if repo_path.exists() and any(repo_path.iterdir()) and not (repo_path / ".git").exists():
        print(f"  [error] {repo_path} exists and isn't empty / isn't a git repo. Pick a different path.")
        return 8
    repo_path.mkdir(parents=True, exist_ok=True)
    print(f"  [ok] {repo_path}")

    if not (repo_path / ".git").exists():
        subprocess.run(["git", "-C", str(repo_path), "init", "-q", "-b", "main"], check=True)
        print("  [ok] initialized git repo")

    print()
    print("Already have a helium-data remote (e.g. from another device)? Enter its URL.")
    print("Leave empty if this is your first device.")
    remote_url = _ask("Remote URL: ", default="").strip()

    is_adopt = False
    if remote_url:
        existing = subprocess.run(
            ["git", "-C", str(repo_path), "remote", "get-url", "origin"],
            capture_output=True, text=True,
        )
        if existing.returncode == 0:
            subprocess.run(["git", "-C", str(repo_path), "remote", "set-url", "origin", remote_url], check=True)
        else:
            subprocess.run(["git", "-C", str(repo_path), "remote", "add", "origin", remote_url], check=True)
        print(f"  [ok] origin -> {remote_url}")

        ls_remote = subprocess.run(
            ["git", "-C", str(repo_path), "ls-remote", "origin", "main"],
            capture_output=True, text=True,
        )
        if ls_remote.stdout.strip():
            is_adopt = True
            print("  [ok] remote has existing canonical state — this is an ADOPT situation")
            subprocess.run(
                ["git", "-C", str(repo_path), "fetch", "origin", "main", "--quiet"],
                check=True,
            )
            subprocess.run(
                ["git", "-C", str(repo_path), "checkout", "-q", "-B", "main", "origin/main"],
                check=True,
            )
        else:
            print("  [ok] remote is empty — first-device flow")

    DEFAULT_CONFIG.parent.mkdir(parents=True, exist_ok=True)
    DEFAULT_CONFIG.write_text(f'repo = "{repo_path.as_posix()}"\n')
    print(f"  [ok] {DEFAULT_CONFIG}")

    global REPO_ROOT, STATE_DIR, LOGS_DIR
    REPO_ROOT = repo_path
    STATE_DIR = repo_path / "state"
    LOGS_DIR = repo_path / "logs"

    print()
    if is_adopt:
        print("Next: ADOPT — this will REPLACE your local Helium state with the canonical")
        print("from the remote. Backups go to logs/prePull.<timestamp>/.")
        if helium_running():
            print()
            print("WARNING: Helium is running. Close it first, then run:")
            print("    helium-sync adopt")
            return 0
        if not args.yes and _ask("Continue? [y/N]: ", default="n").lower() != "y":
            print("aborted. When you're ready, run: helium-sync adopt")
            return 0
        return cmd_pull(args)
    else:
        print("Next: extract your current Helium state and push to canonical.")
        if not args.yes and _ask("Continue? [Y/n]: ", default="y").lower() not in ("y", ""):
            print("aborted. When you're ready, run: helium-sync init")
            return 0
        rc = cmd_push(args)
        if rc == 0:
            print()
            print("Done. On other devices: install helium-sync, run `helium-sync setup` and")
            print(f"give it the remote URL pointing at this data repo.")
        return rc


def _ask(prompt: str, default: str = "") -> str:
    """input() with a default. Returns the default in non-interactive mode."""
    if not sys.stdin.isatty():
        return default
    try:
        answer = input(prompt).strip()
    except (EOFError, KeyboardInterrupt):
        return default
    return answer or default


def cmd_status(args: argparse.Namespace) -> int:
    print(f"Repo:    {REPO_ROOT}")
    print(f"Profile: {args.profile}")
    print(f"Host:    {hostname()}")
    print(f"Helium running here: {'yes' if helium_running() else 'no'}")
    print()

    print("Recent commits:")
    out = run_git(["log", "--oneline", "--decorate", "-5"], check=False).stdout
    for line in (out.strip() or "(none)").splitlines():
        print(f"  {line}")

    try:
        ahead_behind = run_git(
            ["rev-list", "--left-right", "--count", "HEAD...@{u}"],
            check=False,
        ).stdout.strip()
        if ahead_behind and not ahead_behind.startswith("fatal"):
            ahead, behind = ahead_behind.split()
            if int(ahead) or int(behind):
                print(f"  (ahead {ahead}, behind {behind} vs origin)")
    except Exception:
        pass
    print()

    print("Per target:")
    for target in ALL_TARGETS:
        if hasattr(args, "target") and args.target and target.name != args.target:
            continue
        state_file = STATE_DIR / target.state_filename
        try:
            live = target.extract(args.profile)
        except Exception as e:
            print(f"  {target.name:<18} extract failed: {e}")
            continue

        live_summary = _summary(target, live)

        if not state_file.exists():
            print(f"  {target.name:<18} live={live_summary}; canonical=(absent -- run `helium-sync init`)")
            continue

        canonical = target.deserialize(state_file.read_text())

        if target.semantically_equal(live, canonical):
            print(f"  {target.name:<18} [ok] {live_summary}  (in sync)")
        else:
            canon_summary = _summary(target, canonical)
            diff = _format_diff(target, live, canonical)
            print(f"  {target.name:<18} live={live_summary} | canonical={canon_summary} | {diff}")

    return 0


def cmd_diff(args: argparse.Namespace) -> int:
    """Show a human-readable diff between live profile and canonical state."""
    print(f"Repo:    {REPO_ROOT}")
    print(f"Profile: {args.profile}")
    print(f"Host:    {hostname()}")
    print()

    for target in ALL_TARGETS:
        if getattr(args, "target", None) and target.name != args.target:
            continue
        state_file = STATE_DIR / target.state_filename
        try:
            live = target.extract(args.profile)
        except Exception as e:
            print(f"  {target.name}: extract failed: {e}")
            continue

        if not state_file.exists():
            print(f"  {target.name}: no canonical state (run `helium-sync init` first)")
            continue

        canonical = target.deserialize(state_file.read_text())

        if target.semantically_equal(live, canonical):
            print(f"  {target.name}: in sync — no changes")
            print()
            continue

        if target.name == "bookmarks":
            _print_bookmark_diff(live, canonical)
        else:
            print(f"  {target.name}: differs from canonical")
            print("    (use `helium-sync status` for details)")
        print()

    return 0


def _bookmark_url_map(tree: dict) -> dict:
    """Flatten bookmark tree into {(parent_path, url): name} for comparison."""
    result: dict = {}
    if "roots" not in tree:
        return result
    for rk in ("bookmark_bar", "other", "synced"):
        root = tree["roots"].get(rk)
        if root:
            _walk_urls_into(rk, root, result)
    return result


def _walk_urls_into(path: str, node: dict, result: dict) -> None:
    for c in node.get("children") or []:
        if c.get("type") == "url":
            url = c.get("url", "")
            name = c.get("name", "")
            result[(path, url)] = name
        elif c.get("type") == "folder":
            folder_name = c.get("name", "?")
            _walk_urls_into(f"{path}/{folder_name}", c, result)


def _print_bookmark_diff(live: dict, canonical: dict) -> None:
    live_urls = _bookmark_url_map(live)
    canon_urls = _bookmark_url_map(canonical)

    all_keys = sorted(set(live_urls) | set(canon_urls))
    if not all_keys:
        print("  bookmarks: (empty)")
        return

    print("  bookmarks:")

    added, removed, changed = [], [], []
    for key in all_keys:
        in_live = key in live_urls
        in_canon = key in canon_urls
        if in_canon and not in_live:
            removed.append(key)
        elif in_live and not in_canon:
            added.append(key)
        elif live_urls[key] != canon_urls[key]:
            changed.append(key)

    for path, url in removed:
        print(f"    - [{path}] {canon_urls[(path, url)]} ({url})")
    for path, url in changed:
        print(f"    ~ [{path}] {canon_urls[(path, url)]} -> {live_urls[(path, url)]} ({url})")
    for path, url in added:
        print(f"    + [{path}] {live_urls[(path, url)]} ({url})")


def cmd_doctor(args: argparse.Namespace) -> int:
    failures = 0
    warnings = 0

    def report(level: str, name: str, detail: str) -> None:
        nonlocal failures, warnings
        if level == "fail":
            failures += 1
        elif level == "warn":
            warnings += 1
        print(f"[{level}] {name:<20} {detail}")

    print("helium-sync doctor")
    print()

    if _git_available():
        git_version = subprocess.run(["git", "--version"], capture_output=True, text=True, check=False)
        report("ok", "git", (git_version.stdout or "available").strip())
    else:
        report("fail", "git", "git was not found on PATH")

    if _venv_py.exists():
        report("ok", "python venv", str(_venv_py))
    else:
        report("warn", "python venv", f"not found at {_venv_py}")

    tool = _leveldb_writer_path()
    if tool.exists():
        report("ok", "leveldb-writer", str(tool))
    else:
        report("fail", "leveldb-writer", f"not found at {tool}")

    profile = Path(args.profile)
    if profile.exists():
        report("ok", "profile", str(profile))
        default_dir = profile / "Default"
        if default_dir.exists():
            report("ok", "profile Default", str(default_dir))
        else:
            report("warn", "profile Default", f"not found at {default_dir}")
    else:
        report("fail", "profile", f"not found at {profile}")

    if DEFAULT_CONFIG.exists():
        try:
            cfg = tomllib.loads(DEFAULT_CONFIG.read_text())
            cfg_repo = cfg.get("repo")
            if cfg_repo:
                report("ok", "config", f"{DEFAULT_CONFIG} -> {cfg_repo}")
            else:
                report("warn", "config", f"{DEFAULT_CONFIG} has no repo value")
        except (tomllib.TOMLDecodeError, OSError) as e:
            report("fail", "config", f"cannot read {DEFAULT_CONFIG}: {e}")
    else:
        report("warn", "config", f"not found at {DEFAULT_CONFIG}")

    if REPO_ROOT.exists():
        report("ok", "repo", str(REPO_ROOT))
        if (REPO_ROOT / ".git").exists():
            report("ok", "repo git", ".git exists")
            remote = run_git(["remote", "get-url", "origin"], check=False)
            if remote.returncode == 0 and remote.stdout.strip():
                report("ok", "remote", remote.stdout.strip())
            else:
                report("warn", "remote", "origin is not configured")
        else:
            report("fail", "repo git", f"{REPO_ROOT} is not a git repo")
    else:
        report("fail", "repo", f"not found at {REPO_ROOT}")

    if _is_scoop_install():
        report("ok", "scoop", str(_repo))
    else:
        shim = shutil.which("helium-sync")
        if shim:
            report("warn", "scoop", f"shim found at {shim}, install root is {_repo}")
        else:
            report("warn", "scoop", "not detected")

    print()
    if failures:
        print(f"doctor found {failures} failure(s) and {warnings} warning(s)")
        return 1
    print(f"doctor found 0 failures and {warnings} warning(s)")
    return 0


def cmd_version(args: argparse.Namespace) -> int:
    tool = _leveldb_writer_path()
    print(f"helium-sync {_app_version()}")
    print(f"git revision: {_git_revision()}")
    print(f"python: {sys.version.split()[0]} ({sys.executable})")
    print(f"leveldb-writer: {'found' if tool.exists() else 'missing'} ({tool})")
    return 0


def _summary(target, data) -> str:
    if target.name == "bookmarks":
        n_urls = sum(1 for _ in _walk_urls(data))
        return f"{n_urls} URLs"
    if target.name == "saved_tab_groups":
        return f"{len(data.get('groups', {}))} groups, {len(data.get('tabs', {}))} tabs"
    return "?"


def _counts(target, data) -> list[tuple[str, int]]:
    if target.name == "bookmarks":
        return [("URLs", sum(1 for _ in _walk_urls(data)))]
    if target.name == "saved_tab_groups":
        return [
            ("groups", len(data.get("groups", {}))),
            ("tabs",   len(data.get("tabs", {}))),
        ]
    return []


def _format_diff(target, live, canonical) -> str:
    parts = []
    for (label, n_l), (_, n_c) in zip(_counts(target, live), _counts(target, canonical)):
        delta = n_l - n_c
        if delta != 0:
            parts.append(f"{delta:+d} {label}")
    return ", ".join(parts) if parts else "differs (push to propagate)"


def _walk_urls(tree):
    for root in tree.get("roots", {}).values():
        yield from _walk_urls_rec(root)


def _walk_urls_rec(node):
    for c in node.get("children") or []:
        if c.get("type") == "url":
            yield c
        elif c.get("type") == "folder":
            yield from _walk_urls_rec(c)


def cmd_push(args) -> int:
    log(f"=== push from {hostname()} ===")

    if getattr(args, "dry_run", False):
        return _push_dry_run(args)

    has_upstream = _has_upstream()

    if has_upstream:
        log("git pull --rebase...")
        try:
            run_git(["pull", "--rebase", "--quiet"])
        except subprocess.CalledProcessError as e:
            log(f"git pull failed: {(e.stderr or '').strip()}")
            return 1
    else:
        log("(no upstream configured -- skipping git pull)")

    STATE_DIR.mkdir(parents=True, exist_ok=True)
    any_change = False
    for target in ALL_TARGETS:
        if getattr(args, "target", None) and target.name != args.target:
            continue
        log(f"  extract {target.name}...")
        try:
            data = target.extract(args.profile)
        except Exception as e:
            log(f"  extract {target.name} failed: {e}")
            return 2

        # Pre-push validation
        if target.name == "bookmarks":
            issues = _validate_bookmarks(data)
        elif target.name == "saved_tab_groups":
            issues = _validate_tab_groups(data)
        else:
            issues = []

        if issues:
            for issue in issues:
                log(f"  {target.name} WARNING: {issue}")
            if getattr(args, "strict", False):
                log(f"  {target.name}: validation failed (--strict mode)")
                return 9

        state_file = STATE_DIR / target.state_filename
        text = target.serialize(data)
        prev = state_file.read_text() if state_file.exists() else None
        if text != prev:
            state_file.write_text(text)
            any_change = True
            log(f"  {target.name}: wrote {len(text)} bytes ({_summary(target, data)})")
        else:
            log(f"  {target.name}: unchanged")

    if not any_change:
        log("no changes to push")
        if not _has_upstream() and _has_remote():
            log("git push -u origin main (setting upstream)...")
            try:
                run_git(["push", "-u", "origin", "main", "--quiet"])
                log("pushed to origin (upstream now set)")
            except subprocess.CalledProcessError as e:
                log(f"push failed: {(e.stderr or '').strip()}")
                return 3
        return 0

    run_git(["add", "state/"])
    diff = run_git(["diff", "--staged", "--quiet"], check=False)
    if diff.returncode == 0:
        log("nothing actually staged after add")
        return 0

    msg = f"push from {hostname()} {now_iso()}"
    run_git(["commit", "-q", "-m", msg])
    log(f"committed: {msg}")

    if not has_upstream:
        if not _has_remote():
            log("(no remote configured -- local commit only; "
                "add a remote with: git -C <repo> remote add origin <url>)")
            return 0
        # Remote exists but no tracking branch yet — first push, set upstream.
        log("git push -u origin main (first push)...")
        try:
            run_git(["push", "-u", "origin", "main", "--quiet"])
            log("pushed to origin (upstream now set)")
            return 0
        except subprocess.CalledProcessError as e:
            log(f"push failed: {(e.stderr or '').strip()}")
            return 3

    log("git push...")
    try:
        run_git(["push", "--quiet"])
        log("pushed to origin")
        return 0
    except subprocess.CalledProcessError as e:
        log(f"push rejected: {(e.stderr or '').strip()}")
        log("retrying with pull --rebase...")
        try:
            run_git(["pull", "--rebase", "--quiet"])
            run_git(["push", "--quiet"])
            log("pushed on retry")
            return 0
        except subprocess.CalledProcessError as e2:
            log(f"retry failed: {(e2.stderr or '').strip()}")
            log("manual intervention needed: `git pull --rebase` then `git push`")
            return 3


def cmd_pull(args) -> int:
    log(f"=== pull on {hostname()} ===")

    if getattr(args, "dry_run", False):
        return _pull_dry_run(args)

    if not args.allow_helium_running and helium_running():
        print("ERROR: Helium is running on this device.")
        print("Pull writes directly to your Helium profile; close Helium first.")
        print("(Or, for testing: --allow-helium-running)")
        return 4

    has_upstream = _has_upstream()

    if has_upstream:
        log("git pull --rebase...")
        try:
            run_git(["pull", "--rebase", "--quiet"])
        except subprocess.CalledProcessError as e:
            log(f"git pull failed: {(e.stderr or '').strip()}")
            return 1
    else:
        log("(no upstream configured -- nothing to pull from remote)")

    backup_root = LOGS_DIR / f"prePull.{now_stamp()}"
    backup_root.mkdir(parents=True, exist_ok=True)

    n_applied = 0
    for target in ALL_TARGETS:
        if getattr(args, "target", None) and target.name != args.target:
            continue
        state_file = STATE_DIR / target.state_filename
        if not state_file.exists():
            log(f"  {target.name}: no canonical state in repo -- skipping (run init on the source device)")
            continue

        log(f"  apply {target.name}...")
        try:
            data = target.deserialize(state_file.read_text())
            target.apply(args.profile, data, backup_root)
        except Exception as e:
            log(f"  apply {target.name} failed: {e}")
            return 5
        log(f"  {target.name}: applied ({_summary(target, data)})")
        n_applied += 1

    log(f"backup: {backup_root.relative_to(REPO_ROOT)}")
    log(f"done. {n_applied} target(s) applied. Launch Helium to see the synced state.")
    return 0


def cmd_init(args) -> int:
    canonical_exists = any((STATE_DIR / t.state_filename).exists() for t in ALL_TARGETS)
    if canonical_exists and not args.force:
        print(f"ERROR: canonical state already exists in {STATE_DIR.relative_to(REPO_ROOT)}/")
        print("If you really want to overwrite it, pass --force.")
        return 6
    return cmd_push(args)


def cmd_log(args) -> int:
    fmt = "%C(yellow)%h%C(reset)  %C(cyan)%ad%C(reset)  %s"
    color = "always" if sys.stdout.isatty() else "never"
    out = run_git(
        ["log", f"--max-count={args.n}", f"--pretty=format:{fmt}",
         "--date=format:%Y-%m-%d %H:%M", f"--color={color}"],
        check=False,
    ).stdout
    if not out.strip():
        print("(no commits)")
        return 0
    print(out)
    return 0


_BACKUP_PATTERN = re.compile(r"^(prePull|preSync)\.(\d{8}-\d{6})$")


def cmd_gc(args) -> int:
    if not LOGS_DIR.exists():
        print("no logs/ directory yet -- nothing to gc")
        return 0

    cutoff = datetime.now() - timedelta(days=args.keep_days)

    matched = []
    for entry in LOGS_DIR.iterdir():
        if not entry.is_dir():
            continue
        m = _BACKUP_PATTERN.match(entry.name)
        if not m:
            continue
        try:
            ts = datetime.strptime(m.group(2), "%Y%m%d-%H%M%S")
        except ValueError:
            continue
        if ts < cutoff:
            size = sum(f.stat().st_size for f in entry.rglob("*") if f.is_file())
            matched.append((entry, ts, size))

    if not matched:
        print(f"no backups older than {args.keep_days} day(s) -- nothing to prune")
        return 0

    matched.sort(key=lambda t: t[1])
    total = 0
    print(f"backups older than {args.keep_days} day(s):")
    for entry, ts, size in matched:
        print(f"  {entry.name:<32} {ts:%Y-%m-%d %H:%M}  {size//1024:>6} KB")
        total += size
    print(f"  {'total':<32} {' ':<16}  {total//1024:>6} KB")

    if args.dry_run:
        print("(dry run -- pass without --dry-run to actually delete)")
        return 0

    for entry, _, _ in matched:
        shutil.rmtree(entry)
    print(f"deleted {len(matched)} backup directories ({total//1024} KB)")
    return 0


def cmd_adopt(args) -> int:
    print("This will REPLACE your local Helium bookmarks and saved tab groups")
    print("with the canonical state from the repo.")
    print("Backups go to logs/prePull.<timestamp>/.")
    print()
    if not args.yes:
        try:
            answer = input("Continue? [y/N] ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            answer = "n"
        if answer != "y":
            print("aborted")
            return 7
    args.allow_helium_running = False
    return cmd_pull(args)


def cmd_export(args) -> int:
    """Export canonical state to a portable JSON file."""
    if args.target:
        targets_to_export = [t for t in ALL_TARGETS if t.name == args.target]
        if not targets_to_export:
            print(f"  [error] unknown target: {args.target}")
            return 1
    else:
        targets_to_export = ALL_TARGETS

    export_data: dict = {}
    for target in targets_to_export:
        state_file = STATE_DIR / target.state_filename
        if not state_file.exists():
            print(f"  {target.name}: no canonical state to export (run `helium-sync init` first)")
            continue
        export_data[target.name] = {
            "format_version": 1,
            "target": target.name,
            "data": target.deserialize(state_file.read_text()),
        }

    if not export_data:
        print("  nothing to export")
        return 1

    payload = {
        "exported_at": now_iso(),
        "exported_from": hostname(),
        "targets": export_data,
    }

    if args.output:
        out_path = Path(args.output).expanduser().resolve()
    else:
        out_path = REPO_ROOT / f"helium-sync-export-{now_stamp()}.json"

    out_path.parent.mkdir(parents=True, exist_ok=True)
    out_path.write_text(json.dumps(payload, indent=2, ensure_ascii=False))
    print(f"  exported {len(export_data)} target(s) to {out_path}")
    for name in export_data:
        print(f"    - {name}")
    return 0


def cmd_import(args) -> int:
    """Import state from a portable JSON file into the profile."""
    import_path = Path(args.import_file).expanduser().resolve()
    if not import_path.exists():
        print(f"  [error] file not found: {import_path}")
        return 1

    try:
        payload = json.loads(import_path.read_text())
    except (json.JSONDecodeError, OSError) as e:
        print(f"  [error] cannot parse import file: {e}")
        return 1

    if not isinstance(payload, dict) or "targets" not in payload:
        print("  [error] invalid export format — missing 'targets' key")
        return 1

    if not args.allow_helium_running and helium_running():
        print("ERROR: Helium is running on this device.")
        print("Import writes directly to your Helium profile; close Helium first.")
        print("(Or, for testing: --allow-helium-running)")
        return 4

    backup_root = LOGS_DIR / f"preImport.{now_stamp()}"
    backup_root.mkdir(parents=True, exist_ok=True)

    n_applied = 0
    for target in ALL_TARGETS:
        target_data = payload["targets"].get(target.name)
        if not target_data:
            continue
        if args.target and target.name != args.target:
            continue

        data = target_data.get("data")
        if data is None:
            print(f"  {target.name}: no data in export file — skipping")
            continue

        print(f"  apply {target.name}...")
        try:
            target.apply(args.profile, data, backup_root)
        except Exception as e:
            print(f"  apply {target.name} failed: {e}")
            return 5
        print(f"  {target.name}: applied")
        n_applied += 1

    if n_applied == 0:
        print("  no matching targets found in import file")
        return 1

    print(f"  backup: {backup_root.relative_to(REPO_ROOT)}")
    print(f"  done. {n_applied} target(s) applied. Launch Helium to see the imported state.")
    return 0


def _push_dry_run(args) -> int:
    """Show what would change during push without committing or pushing."""
    log(f"=== push dry-run from {hostname()} ===")
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    any_change = False
    for target in ALL_TARGETS:
        if getattr(args, "target", None) and target.name != args.target:
            continue
        try:
            data = target.extract(args.profile)
        except Exception as e:
            log(f"  extract {target.name} failed: {e}")
            return 2

        if target.name == "bookmarks":
            issues = _validate_bookmarks(data)
        elif target.name == "saved_tab_groups":
            issues = _validate_tab_groups(data)
        else:
            issues = []
        if issues:
            for issue in issues:
                log(f"  {target.name} WARNING: {issue}")

        state_file = STATE_DIR / target.state_filename
        text = target.serialize(data)
        prev = state_file.read_text() if state_file.exists() else None
        if text != prev:
            any_change = True
            log(f"  {target.name}: WOULD UPDATE ({_summary(target, data)})")
            if prev:
                prev_size = len(prev)
                delta = len(text) - prev_size
                log(f"    size: {prev_size} -> {len(text)} bytes ({delta:+d})")
            else:
                log(f"    new file: {len(text)} bytes")
        else:
            log(f"  {target.name}: unchanged")

    if not any_change:
        log("no changes to push")
    else:
        log("would commit and push changes")
        if not _has_upstream() and _has_remote():
            log("  (would set upstream: git push -u origin main)")
        elif not _has_remote():
            log("  (local commit only -- no remote configured)")
    print("(dry run -- pass without --dry-run to actually commit and push)")
    return 0


def _pull_dry_run(args) -> int:
    """Show what would change during pull without pulling or writing."""
    log(f"=== pull dry-run on {hostname()} ===")
    log("would: git pull --rebase")

    n_would_apply = 0
    for target in ALL_TARGETS:
        if getattr(args, "target", None) and target.name != args.target:
            continue
        state_file = STATE_DIR / target.state_filename
        if not state_file.exists():
            log(f"  {target.name}: no canonical state -- would skip")
            continue
        try:
            data = target.deserialize(state_file.read_text())
            n_would_apply += 1
            log(f"  {target.name}: would apply ({_summary(target, data)})")
        except Exception as e:
            log(f"  {target.name}: would fail -- {e}")

    if n_would_apply == 0:
        log("nothing to pull")
    else:
        log(f"would apply {n_would_apply} target(s)")
        log("would backup current profile to logs/prePull.<timestamp>/")
    print("(dry run -- pass without --dry-run to actually pull and write to profile)")
    return 0


_BACKUP_RESTORE_PATTERN = re.compile(r"^(prePull|preImport|preSync)\.(\d{8}-\d{6})$")


def cmd_restore(args) -> int:
    """Restore profile from the latest backup in logs/."""
    if not LOGS_DIR.exists():
        print("no logs/ directory -- no backups to restore from")
        return 1

    if not args.allow_helium_running and helium_running():
        print("ERROR: Helium is running on this device.")
        print("Restore writes to your Helium profile; close Helium first.")
        print("(Or, for testing: --allow-helium-running)")
        return 4

    backups = []
    for entry in LOGS_DIR.iterdir():
        if not entry.is_dir():
            continue
        m = _BACKUP_RESTORE_PATTERN.match(entry.name)
        if m:
            try:
                ts = datetime.strptime(m.group(2), "%Y%m%d-%H%M%S")
                backups.append((entry, ts))
            except ValueError:
                continue

    if not backups:
        print("no backups found in logs/ (looked for prePull.*, preImport.*, preSync.*)")
        return 1

    backups.sort(key=lambda x: x[1], reverse=True)
    latest, ts = backups[0]
    print(f"restoring from latest backup: {latest.name}")
    print(f"  backup time: {ts:%Y-%m-%d %H:%M:%S}")
    print(f"  files: {[f.name for f in latest.iterdir()]}")
    print()

    restored = 0
    for src in latest.iterdir():
        if src.is_file():
            dst = args.profile / src.name
            dst.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(str(src), str(dst))
            print(f"  restored {src.name} -> {dst}")
            restored += 1

    if restored == 0:
        print("no files found in backup directory")
        return 1

    print(f"\nrestored {restored} file(s). Launch Helium to see the restored state.")
    return 0


def cmd_resolve(args: argparse.Namespace) -> int:
    """Dispatch to bookmark or tab-group interactive resolver."""
    target = getattr(args, "target", None) or "bookmarks"
    if target == "bookmarks":
        return _resolve_bookmarks(args)
    if target == "saved_tab_groups":
        return _resolve_tab_groups(args)
    print(f"resolve: unknown target '{target}' (choose: bookmarks, saved_tab_groups)")
    return 1


def _resolve_bookmarks(args: argparse.Namespace) -> int:
    """Interactively merge divergent bookmark states."""
    import msvcrt

    if args.theirs:
        theirs_path = Path(args.theirs).expanduser().resolve()
        if not theirs_path.exists():
            print(f"file not found: {theirs_path}")
            return 1
        try:
            theirs_data = json.loads(theirs_path.read_text())
        except (json.JSONDecodeError, OSError) as e:
            print(f"cannot parse file: {e}")
            return 1
    else:
        state_file = STATE_DIR / "bookmarks.json"
        if not state_file.exists():
            print("no canonical bookmarks state -- nothing to resolve against")
            return 1
        theirs_data = json.loads(state_file.read_text())

    try:
        live_data = None
        for t in ALL_TARGETS:
            if t.name == "bookmarks" or (live_data is None and "bookmark" in t.name.lower()):
                live_data = t.extract(args.profile)
                break
        if live_data is None:
            print("no bookmarks target found")
            return 2
    except Exception as e:
        print(f"cannot extract live bookmarks: {e}")
        return 2

    # Build URL maps
    def url_map(tree):
        result = {}
        for node in _walk_urls(tree):
            url = node.get("url", "")
            result[url] = node
        return result

    live_urls = url_map(live_data)
    theirs_urls = url_map(theirs_data)

    live_only = set(live_urls) - set(theirs_urls)
    theirs_only = set(theirs_urls) - set(live_urls)
    common = set(live_urls) & set(theirs_urls)

    # Check for conflicts in common URLs (different name/parent)
    conflicts = []
    for url in sorted(common):
        l = live_urls[url]
        t = theirs_urls[url]
        if l.get("name") != t.get("name"):
            conflicts.append(url)

    if not live_only and not theirs_only and not conflicts:
        print("no divergences found -- live and canonical are identical")
        return 0

    print(f"divergences found:")
    print(f"  only on this device: {len(live_only)} bookmark(s)")
    print(f"  only in canonical:   {len(theirs_only)} bookmark(s)")
    print(f"  name conflicts:      {len(conflicts)} bookmark(s)")
    print()

    if not sys.stdin.isatty():
        print("(resolve requires an interactive terminal)")
        print("Run: helium-sync pull --dry-run   to see what would change")
        return 1

    # Interactive TUI
    items = []
    for url in sorted(live_only):
        items.append({
            "url": url,
            "name": live_urls[url].get("name", "(untitled)"),
            "source": "local",
            "keep": True,
            "conflict": False,
        })
    for url in sorted(theirs_only):
        items.append({
            "url": url,
            "name": theirs_urls[url].get("name", "(untitled)"),
            "source": "canonical",
            "keep": True,
            "conflict": False,
        })
    for url in sorted(conflicts):
        items.append({
            "url": url,
            "name": live_urls[url].get("name", "(untitled)"),
            "theirs_name": theirs_urls[url].get("name", "(untitled)"),
            "source": "conflict",
            "keep": True,
            "keep_theirs": False,
            "conflict": True,
        })

    cursor = 0
    width = max(72, max((len(item['name']) + 20 for item in items), default=72))

    # Windows console colors via ctypes (no deps)
    import ctypes
    h = ctypes.windll.kernel32.GetStdHandle(-11)  # STD_OUTPUT_HANDLE
    RESET = '\033[0m' if os.environ.get('WT_SESSION') or os.environ.get('TERM') else ''
    GREEN = '\033[32m' if os.environ.get('WT_SESSION') or os.environ.get('TERM') else ''
    CYAN = '\033[36m' if os.environ.get('WT_SESSION') or os.environ.get('TERM') else ''
    YELLOW = '\033[33m' if os.environ.get('WT_SESSION') or os.environ.get('TERM') else ''
    BOLD = '\033[1m' if os.environ.get('WT_SESSION') or os.environ.get('TERM') else ''
    DIM = '\033[2m' if os.environ.get('WT_SESSION') or os.environ.get('TERM') else ''

    def _color(text, color_code):
        return f'{color_code}{text}{RESET}' if RESET else text

    def _truncate_url(url, max_len=60):
        if len(url) <= max_len:
            return url
        return '...' + url[-(max_len - 3):]

    def _render():
        os.system("cls" if os.name == "nt" else "clear")
        print(f'{BOLD}Resolve bookmark divergences{RESET}')
        print(f'{DIM}↑↓ navigate  Space toggle  Enter apply  Q quit{RESET}')
        print('─' * width)

        selected = 0
        total = 0
        for i, item in enumerate(items):
            total += 1
            if item["conflict"]:
                sel = "[*]" if item.get("keep_theirs", False) else "[ ]"
                arrow = f"{BOLD}>>{RESET}" if i == cursor else "  "
                local_sel = "[ ]" if item["keep"] else "[ ]"
                if item["keep"]:
                    local_sel = f"{GREEN}[x]{RESET}"
                else:
                    local_sel = f"{DIM}[ ]{RESET}"

                theirs_sel = f"{CYAN}[x]{RESET}" if item.get("keep_theirs", False) else f"{DIM}[ ]{RESET}"
                url_display = _truncate_url(item['url'])

                if i == cursor:
                    print(f'{BOLD}▼{RESET} {local_sel}  {GREEN}local{RESET}:   {item["name"]}')
                    print(f'  {theirs_sel}  {CYAN}remote{RESET}:  {item.get("theirs_name", "?")}')
                    print(f'  {DIM}{url_display}{RESET}')
                else:
                    print(f'  {local_sel}  {GREEN}local{RESET}:   {item["name"]}')
                    print(f'  {theirs_sel}  {CYAN}remote{RESET}:  {item.get("theirs_name", "?")}')
                    print(f'  {DIM}{url_display}{RESET}')

                if i < len(items) - 1:
                    print()
            else:
                arrow = f"{BOLD}>>{RESET}" if i == cursor else "  "
                if item["source"] == "local":
                    tag = f'{GREEN}local{RESET}'
                    sel = f'{GREEN}[x]{RESET}' if item["keep"] else f'{DIM}[ ]{RESET}'
                    if item["keep"]:
                        selected += 1
                else:
                    tag = f'{CYAN}remote{RESET}'
                    sel = f'{CYAN}[x]{RESET}' if item["keep"] else f'{DIM}[ ]{RESET}'
                    if item["keep"]:
                        selected += 1

                url_display = _truncate_url(item['url'])
                if i == cursor:
                    print(f'{BOLD}▼ {sel}  {tag}  {item["name"]}{RESET}')
                    print(f'  {DIM}{url_display}{RESET}')
                else:
                    print(f'  {sel}  {tag}  {item["name"]}')
                    print(f'  {DIM}{url_display}{RESET}')

                if i < len(items) - 1:
                    print()

        print('─' * width)
        print(f'{selected}/{total} bookmarks selected  {BOLD}Enter{RESET} to apply  {BOLD}Q{RESET} to cancel')

    _render()
    while True:
        try:
            key = msvcrt.getch()
        except (KeyboardInterrupt, EOFError):
            print("\naborted")
            return 7

        if key == b"\xe0":  # arrow keys
            key = msvcrt.getch()
            if key == b"H" and cursor > 0:
                cursor -= 1
            elif key == b"P" and cursor < len(items) - 1:
                cursor += 1
        elif key == b" ":
            item = items[cursor]
            if item["conflict"]:
                item["keep_theirs"] = not item.get("keep_theirs", False)
            else:
                item["keep"] = not item["keep"]
        elif key in (b"\r", b"\n"):
            break
        elif key.lower() == b"q":
            print("\nresolve cancelled — no changes applied")
            return 0
        _render()

    # Apply resolution: rebuild bookmark tree
    new_roots = {}
    for root_key, root_node in live_data.get("roots", {}).items():
        new_root = _merge_bookmark_tree(root_node, live_urls, theirs_urls, items)
        new_roots[root_key] = new_root

    merged = {
        "roots": new_roots,
        "checksum": "",
        "version": live_data.get("version", 1),
    }

    backup_root = LOGS_DIR / f"preSync.{now_stamp()}"
    bm_target = next(t for t in ALL_TARGETS if t.name == "bookmarks")
    try:
        bm_target.apply(args.profile, merged, backup_root)
    except Exception as e:
        print(f"\nfailed to write merged bookmarks: {e}")
        return 2

    kept_local = sum(1 for i in items if i["source"] == "local" and i["keep"])
    kept_theirs = sum(1 for i in items if i["source"] == "canonical" and i["keep"])
    print(f"\nresolved: kept {kept_local} local + {kept_theirs} canonical bookmark(s)")
    print(f"backup: {backup_root.relative_to(REPO_ROOT)}")
    return 0


def _merge_bookmark_tree(node, live_urls, theirs_urls, items):
    """Rebuild a bookmark tree keeping only selected items."""
    new_node = dict(node)
    children = []
    for child in node.get("children", []):
        if child.get("type") == "url":
            url = child.get("url", "")
            item = next((i for i in items if i["url"] == url), None)
            if item is None:
                children.append(child)
            elif item["source"] == "local" and item["keep"]:
                children.append(child)
            elif item["source"] == "canonical" and item["keep"]:
                children.append(child)
            elif item["source"] == "conflict":
                if item.get("keep_theirs", False):
                    tc = dict(child)
                    tc["name"] = item.get("theirs_name", child.get("name", ""))
                    children.append(tc)
                elif item["keep"]:
                    children.append(child)
            # else: dropped
        elif child.get("type") == "folder":
            merged = _merge_bookmark_tree(child, live_urls, theirs_urls, items)
            if merged.get("children"):
                children.append(merged)
    new_node["children"] = children
    return new_node


def _resolve_tab_groups(args: argparse.Namespace) -> int:
    """Interactively merge divergent saved tab group states."""
    import msvcrt

    if helium_running():
        print("ERROR: Helium is running on this device.")
        print("Tab group resolve writes to the live profile; close Helium first.")
        return 4

    if args.theirs:
        theirs_path = Path(args.theirs).expanduser().resolve()
        if not theirs_path.exists():
            print(f"file not found: {theirs_path}")
            return 1
        try:
            theirs_data = json.loads(theirs_path.read_text())
        except (json.JSONDecodeError, OSError) as e:
            print(f"cannot parse file: {e}")
            return 1
    else:
        state_file = STATE_DIR / "saved_tab_groups.json"
        if not state_file.exists():
            print("no canonical saved tab groups state -- nothing to resolve against")
            return 1
        theirs_data = json.loads(state_file.read_text())

    stg_target = next((t for t in ALL_TARGETS if t.name == "saved_tab_groups"), None)
    if stg_target is None:
        print("saved_tab_groups target not available")
        return 1
    try:
        live_data = stg_target.extract(args.profile)
    except Exception as e:
        print(f"cannot extract live saved tab groups: {e}")
        return 2

    divs = _tab_group_divergences(live_data, theirs_data)
    live_only_groups  = divs["live_only_groups"]
    canon_only_groups = divs["canon_only_groups"]
    conflict_groups   = divs["conflict_groups"]
    live_only_tabs    = divs["live_only_tabs"]
    canon_only_tabs   = divs["canon_only_tabs"]
    conflict_tabs     = divs["conflict_tabs"]

    total_divs = (len(live_only_groups) + len(canon_only_groups) + len(conflict_groups) +
                  len(live_only_tabs) + len(canon_only_tabs) + len(conflict_tabs))

    if total_divs == 0:
        print("no divergences found -- live and canonical are identical")
        return 0

    print("divergences found:")
    print(f"  groups only on this device: {len(live_only_groups)}")
    print(f"  groups only in canonical:   {len(canon_only_groups)}")
    print(f"  group conflicts:            {len(conflict_groups)}")
    print(f"  tabs only on this device:   {len(live_only_tabs)}")
    print(f"  tabs only in canonical:     {len(canon_only_tabs)}")
    print(f"  tab conflicts:              {len(conflict_tabs)}")
    print()

    if not sys.stdin.isatty():
        print("(resolve requires an interactive terminal)")
        print("Run: helium-sync pull --dry-run   to see what would change")
        return 1

    lg = live_data["groups"]
    cg = theirs_data["groups"]
    lt = live_data["tabs"]
    ct = theirs_data["tabs"]

    def _tab_count(group_guid: str, tabs: dict) -> int:
        return sum(1 for t in tabs.values() if t.get("group_guid") == group_guid)

    def _group_title(group_guid: str, groups: dict) -> str:
        return groups.get(group_guid, {}).get("title", "?")

    items: list = []

    for guid in sorted(live_only_groups):
        g = lg[guid]
        items.append({"type": "group", "guid": guid,
                      "title": g.get("title", "(untitled)"),
                      "n_tabs": _tab_count(guid, lt),
                      "source": "local", "keep": True, "conflict": False})
    for guid in sorted(canon_only_groups):
        g = cg[guid]
        items.append({"type": "group", "guid": guid,
                      "title": g.get("title", "(untitled)"),
                      "n_tabs": _tab_count(guid, ct),
                      "source": "canonical", "keep": True, "conflict": False})
    for guid in sorted(conflict_groups):
        items.append({"type": "group", "guid": guid,
                      "title":        lg[guid].get("title", "(untitled)"),
                      "theirs_title": cg[guid].get("title", "(untitled)"),
                      "n_tabs": _tab_count(guid, lt),
                      "source": "conflict", "keep": True, "keep_theirs": False, "conflict": True})

    for guid in sorted(live_only_tabs):
        t = lt[guid]
        items.append({"type": "tab", "guid": guid,
                      "title": t.get("title", "(untitled)"),
                      "url":   t.get("url", ""),
                      "group_title": _group_title(t.get("group_guid", ""), lg),
                      "source": "local", "keep": True, "conflict": False})
    for guid in sorted(canon_only_tabs):
        t = ct[guid]
        items.append({"type": "tab", "guid": guid,
                      "title": t.get("title", "(untitled)"),
                      "url":   t.get("url", ""),
                      "group_title": _group_title(t.get("group_guid", ""), cg),
                      "source": "canonical", "keep": True, "conflict": False})
    for guid in sorted(conflict_tabs):
        tl, tc2 = lt[guid], ct[guid]
        items.append({"type": "tab", "guid": guid,
                      "title":        tl.get("title", "(untitled)"),
                      "theirs_title": tc2.get("title", "(untitled)"),
                      "url":          tl.get("url", ""),
                      "theirs_url":   tc2.get("url", ""),
                      "group_title": _group_title(tl.get("group_guid", ""), lg),
                      "source": "conflict", "keep": True, "keep_theirs": False, "conflict": True})

    cursor = 0
    width = 72

    RESET  = '\033[0m'  if os.environ.get('WT_SESSION') or os.environ.get('TERM') else ''
    GREEN  = '\033[32m' if RESET else ''
    CYAN   = '\033[36m' if RESET else ''
    YELLOW = '\033[33m' if RESET else ''
    BOLD   = '\033[1m'  if RESET else ''
    DIM    = '\033[2m'  if RESET else ''

    def _trunc(s: str, n: int = 55) -> str:
        return s if len(s) <= n else '...' + s[-(n - 3):]

    def _render_tab_groups():
        os.system("cls" if os.name == "nt" else "clear")
        print(f'{BOLD}Resolve saved tab group divergences{RESET}')
        print(f'{DIM}↑↓ navigate  Space toggle  Enter apply  Q quit{RESET}')
        print('─' * width)

        kept = 0
        for i, item in enumerate(items):
            is_cur = i == cursor
            arrow  = f'{BOLD}▼{RESET} ' if is_cur else '  '
            prefix = f'{YELLOW}G{RESET}' if item["type"] == "group" else f'{CYAN}T{RESET}'

            if item["conflict"]:
                lsel = f'{GREEN}[x]{RESET}' if item["keep"]             else f'{DIM}[ ]{RESET}'
                rsel = f'{CYAN}[x]{RESET}'  if item.get("keep_theirs") else f'{DIM}[ ]{RESET}'
                if item["keep"] or item.get("keep_theirs"):
                    kept += 1
                if item["type"] == "group":
                    print(f'{arrow}{prefix} {lsel} {GREEN}local{RESET}:  {item["title"]}  ({item["n_tabs"]} tabs)')
                    print(f'     {rsel} {CYAN}remote{RESET}: {item["theirs_title"]}')
                else:
                    print(f'{arrow}{prefix} {lsel} {GREEN}local{RESET}:  {item["title"]}')
                    print(f'       {DIM}{_trunc(item["url"])}{RESET}')
                    print(f'     {rsel} {CYAN}remote{RESET}: {item["theirs_title"]}')
                    print(f'       {DIM}{_trunc(item["theirs_url"])}{RESET}')
            else:
                if item["source"] == "local":
                    tag = f'{GREEN}local{RESET}'
                    sel = f'{GREEN}[x]{RESET}' if item["keep"] else f'{DIM}[ ]{RESET}'
                else:
                    tag = f'{CYAN}remote{RESET}'
                    sel = f'{CYAN}[x]{RESET}' if item["keep"] else f'{DIM}[ ]{RESET}'
                if item["keep"]:
                    kept += 1
                if item["type"] == "group":
                    print(f'{arrow}{prefix} {sel}  {tag}  {item["title"]}  ({item["n_tabs"]} tabs)')
                else:
                    grp = f'{DIM}group: {item["group_title"]}{RESET}' if RESET else f'group: {item["group_title"]}'
                    print(f'{arrow}{prefix} {sel}  {tag}  {item["title"]}  [{grp}]')
                    print(f'       {DIM}{_trunc(item["url"])}{RESET}')

            if i < len(items) - 1:
                print()

        print('─' * width)
        print(f'{kept}/{len(items)} items selected  {BOLD}Enter{RESET} to apply  {BOLD}Q{RESET} to cancel')

    _render_tab_groups()
    while True:
        try:
            key = msvcrt.getch()
        except (KeyboardInterrupt, EOFError):
            print("\naborted")
            return 7

        if key == b"\xe0":
            key = msvcrt.getch()
            if key == b"H" and cursor > 0:
                cursor -= 1
            elif key == b"P" and cursor < len(items) - 1:
                cursor += 1
        elif key == b" ":
            item = items[cursor]
            if item["conflict"]:
                item["keep_theirs"] = not item.get("keep_theirs", False)
            else:
                item["keep"] = not item["keep"]
        elif key in (b"\r", b"\n"):
            break
        elif key.lower() == b"q":
            print("\nresolve cancelled — no changes applied")
            return 0
        _render_tab_groups()

    merged = _merge_tab_groups(live_data, theirs_data, items)

    backup_root = LOGS_DIR / f"preSync.{now_stamp()}"
    try:
        stg_target.apply(args.profile, merged, backup_root)
    except Exception as e:
        print(f"\nfailed to write merged tab groups: {e}")
        return 2

    kept_local  = sum(1 for i in items if i["source"] == "local"     and i["keep"])
    kept_canon  = sum(1 for i in items if i["source"] == "canonical" and i["keep"])
    n_conflicts = sum(1 for i in items if i["source"] == "conflict"  and (i["keep"] or i.get("keep_theirs")))
    print(f"\nresolved: kept {kept_local} local + {kept_canon} canonical, {n_conflicts} conflicts resolved")
    print(f"backup: {backup_root.relative_to(REPO_ROOT)}")
    return 0


def cmd_completion(args) -> int:
    """Generate shell completion script."""
    subs = ["setup", "push", "pull", "status", "diff", "doctor", "version",
            "log", "gc", "init", "adopt", "export", "import", "restore",
            "resolve", "completion"]

    flags_by_sub = {
        "setup": ["--force", "--yes", "-y", "--profile", "--repo"],
        "push": ["--target", "--strict", "--dry-run", "--profile", "--repo"],
        "pull": ["--allow-helium-running", "--target", "--dry-run", "--profile", "--repo"],
        "status": ["--target", "--profile", "--repo"],
        "diff": ["--target", "--profile", "--repo"],
        "doctor": ["--profile", "--repo"],
        "version": [],
        "log": ["-n", "--profile", "--repo"],
        "gc": ["--keep-days", "--dry-run", "--profile", "--repo"],
        "init": ["--force", "--profile", "--repo"],
        "adopt": ["--yes", "-y", "--allow-helium-running", "--profile", "--repo"],
        "export": ["--output", "--target", "--profile", "--repo"],
        "import": ["--allow-helium-running", "--target", "--profile", "--repo"],
        "restore": ["--allow-helium-running", "--profile", "--repo"],
        "resolve": ["--target", "--theirs", "--profile", "--repo"],
        "completion": ["--shell", "--profile", "--repo"],
    }

    if args.shell == "powershell":
        _gen_powershell_completion(subs, flags_by_sub)
    elif args.shell == "cmd":
        _gen_cmd_completion(subs)
    return 0


def _gen_powershell_completion(subs, flags_by_sub):
    sub_lines = "\n".join(f'        "{s}"' for s in subs)
    flag_lines = []
    for s in subs:
        fl = ", ".join(f'"{f}"' for f in flags_by_sub.get(s, []))
        flag_lines.append(f'        "{s}" = @({fl})')
    flags_block = "\n".join(flag_lines)

    script = f"""$scriptBlock = {{
    param($wordToComplete, $commandAst, $cursorPosition)

    $commandElements = $commandAst.CommandElements
    $subcommands = @(
{sub_lines}
    )
    $globalFlags = @("--profile", "--repo", "--help", "-h")

    if ($commandElements.Count -le 2) {{
        $subcommands | Where-Object {{ $_ -like "$wordToComplete*" }}
        return
    }}

    $subcommand = $commandElements[2].Value
    $flags = @(
{flags_block}
    )

    if ($flags.ContainsKey($subcommand)) {{
        $flags[$subcommand] | Where-Object {{ $_ -like "$wordToComplete*" }}
    }}
}}

Register-ArgumentCompleter -CommandName helium-sync -ScriptBlock $scriptBlock
Register-ArgumentCompleter -CommandName helium-sync.bat -ScriptBlock $scriptBlock"""
    print(script)


def _gen_cmd_completion(subs):
    print("@echo off")
    print("REM helium-sync DOSKEY macros for cmd.exe")
    print("REM Usage: helium-sync <TAB>")
    print("REM Note: DOSKEY doesn't support subcommand completion natively.")
    print("REM For best experience, use PowerShell completion instead.")
    print()
    for s in subs:
        print(f"doskey helium-sync {s}=helium-sync {s} $*")


# ──────────────────────────────────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────────────────────────────────

def main() -> int:
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--profile", type=Path, default=DEFAULT_PROFILE,
                        help="Helium profile directory")
    parser.add_argument("--repo", type=Path, default=None,
                        help="data repo path (default: $HELIUM_SYNC_REPO, "
                             "or `repo` in config file, "
                             "or the parent of this script)")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_setup = sub.add_parser("setup", help="interactive first-time configuration")
    p_setup.add_argument("--force", action="store_true",
                         help="overwrite existing config")
    p_setup.add_argument("--yes", "-y", action="store_true",
                         help="skip confirmation prompts (use defaults)")

    p_status = sub.add_parser("status", help="show what's going on (read-only)")
    p_status.add_argument("--target", type=str, default=None,
                          help="show only this target (e.g. bookmarks)")

    p_diff = sub.add_parser("diff", help="human-readable diff between live and canonical")
    p_diff.add_argument("--target", type=str, default=None,
                        help="diff only this target (e.g. bookmarks)")

    sub.add_parser("doctor", help="check local install and sync prerequisites")

    sub.add_parser("version", help="print version and runtime details")

    p_push = sub.add_parser("push", help="snapshot -> repo -> origin (close Helium first)")
    p_push.add_argument("--target", type=str, default=None,
                        help="sync only this target (e.g. bookmarks, saved_tab_groups)")
    p_push.add_argument("--strict", action="store_true",
                        help="fail on validation warnings")
    p_push.add_argument("--dry-run", action="store_true",
                        help="show what would change without committing or pushing")

    p_pull = sub.add_parser("pull", help="origin -> repo -> live profile")
    p_pull.add_argument("--allow-helium-running", action="store_true",
                        help="DANGEROUS -- bypass the running-browser guard")
    p_pull.add_argument("--target", type=str, default=None,
                        help="sync only this target (e.g. bookmarks, saved_tab_groups)")
    p_pull.add_argument("--dry-run", action="store_true",
                        help="show what would change without pulling or writing to profile")

    p_init = sub.add_parser("init", help="first-time: this device is the truth")
    p_init.add_argument("--force", action="store_true",
                        help="overwrite existing canonical state")
    p_init.add_argument("--target", type=str, default=None,
                        help="init only this target (e.g. bookmarks)")

    p_adopt = sub.add_parser("adopt", help="first-time on a new device")
    p_adopt.add_argument("--yes", "-y", action="store_true",
                         help="skip confirmation prompt")
    p_adopt.add_argument("--allow-helium-running", action="store_true",
                         help="DANGEROUS -- bypass the running-browser guard")

    p_gc = sub.add_parser("gc", help="prune old backups in logs/")
    p_gc.add_argument("--keep-days", type=int, default=30,
                      help="prune backups older than this many days (default: 30)")
    p_gc.add_argument("--dry-run", action="store_true",
                      help="show what would be deleted without deleting")

    p_log = sub.add_parser("log", help="show recent sync history")
    p_log.add_argument("-n", type=int, default=10,
                       help="number of commits to show (default: 10)")

    p_export = sub.add_parser("export", help="export canonical state to portable JSON file")
    p_export.add_argument("--output", type=str, default=None,
                          help="output file path (default: helium-sync-export-<ts>.json in repo)")
    p_export.add_argument("--target", type=str, default=None,
                          help="export only this target (e.g. bookmarks)")

    p_import = sub.add_parser("import", help="import state from portable JSON file into profile")
    p_import.add_argument("import_file", help="path to export JSON file")
    p_import.add_argument("--allow-helium-running", action="store_true",
                          help="DANGEROUS -- bypass the running-browser guard")
    p_import.add_argument("--target", type=str, default=None,
                           help="import only this target (e.g. bookmarks)")

    p_restore = sub.add_parser("restore", help="restore profile from latest backup")
    p_restore.add_argument("--allow-helium-running", action="store_true",
                            help="DANGEROUS -- bypass the running-browser guard")

    p_resolve = sub.add_parser("resolve", help="interactively merge divergent states")
    p_resolve.add_argument("--target", type=str, default="bookmarks",
                            choices=["bookmarks", "saved_tab_groups"],
                            help="which target to resolve (default: bookmarks)")
    p_resolve.add_argument("--theirs", type=str, default=None,
                            help="path to canonical JSON to resolve against")

    p_completion = sub.add_parser("completion", help="generate shell completion script")
    p_completion.add_argument("--shell", required=True, choices=["powershell", "cmd"],
                              help="shell to generate completions for")

    args = parser.parse_args()

    global REPO_ROOT, STATE_DIR, LOGS_DIR
    REPO_ROOT = _resolve_repo(args.repo, os.environ, DEFAULT_CONFIG)
    STATE_DIR = REPO_ROOT / "state"
    LOGS_DIR = REPO_ROOT / "logs"

    maybe_show_update_banner()

    handler = {
        "setup":  cmd_setup,
        "status": cmd_status,
        "diff":   cmd_diff,
        "doctor": cmd_doctor,
        "version": cmd_version,
        "push":   cmd_push,
        "pull":   cmd_pull,
        "init":   cmd_init,
        "adopt":  cmd_adopt,
        "gc":     cmd_gc,
        "log":    cmd_log,
        "export": cmd_export,
        "import": cmd_import,
        "restore": cmd_restore,
        "resolve": cmd_resolve,
        "completion": cmd_completion,
    }[args.cmd]
    return handler(args) or 0


if __name__ == "__main__":
    sys.exit(main())
